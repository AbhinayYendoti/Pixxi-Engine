# ─────────────────────────────────────────────────────────────
# Pixii Engine — Backend Environment Variables
# Copy this file to .env and fill in your real values
# These SAME keys must be set in the Render dashboard
# ─────────────────────────────────────────────────────────────

# Rainforest API — Amazon product & review scraping
RAINFOREST_API_KEY=your_rainforest_api_key_here

# NVIDIA NIM — Llama 3.1 8B inference endpoint
NVIDIA_API_KEY=your_nvidia_nim_api_key_here

# Frontend URL — Your Vercel production domain (for CORS)
# Example: https://pixii-engine.vercel.app
FRONTEND_URL=https://your-vercel-app.vercel.app

# Port — Render automatically sets this, but 8080 is a safe default
PORT=8080
